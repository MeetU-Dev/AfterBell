
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/afterbell
# ⚠️ IMPORTANT: Replace with a real secret in production!
# Generate one: openssl rand -hex 64
JWT_SECRET=your-jwt-secret

# SMTP for email notifications (parent verification, reports, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AfterBell <your-email@gmail.com>

# OTP / Twilio SMS
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=+1234567890

# AI Study Buddy (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
